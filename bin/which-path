#!/bin/bash

# See ../doc/bin.md for description

function show_help() {
  cat << 'EOF'
which-path - Find the path of a command in PATH (ignores aliases and functions)

Usage:
  which-path COMMAND
  which-path --help

Arguments:
  COMMAND       Name of the command to find

Options:
  -h, --help    Show this help message

Notes:
  - Uses `whence -p` on zsh, `type -P` on bash
  - Exits with status 1 if the command is not found
EOF
}

[[ $1 == --help || $1 == -h ]] && show_help && exit 0

if [[ $1 == '' ]] ; then
  show_help
  exit 1
fi

command_name=$1

if [[ -n $ZSH_VERSION ]] ; then
  result=$(whence -p "$command_name" 2>/dev/null)
else
  result=$(type -P "$command_name" 2>/dev/null)
fi

if [[ $result == '' ]] ; then
  echo "Command not found: $command_name" >&2
  exit 1
fi

echo "$result"

